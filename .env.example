# DouyinClaw 环境变量配置
# 复制此文件为 .env 并填写实际值

# === 抖音 ===
DOUYIN_SESSION_DIR=./data/sessions
DOUYIN_SESSION_SECRET=abc123xyz789!@aaaaaa

# === AI Provider 配置 ===
# 可选值: claude | glm | qwen | minimax
AI_PROVIDER=glm
AI_MAX_TOKENS=1024

# === Claude (Anthropic) ===
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# === GLM (智谱 AI) ===
GLM_API_KEY=8465230a389a427d88dbfffbb27da4bb.KbLzmUTixyjGcpEl
GLM_MODEL=glm-4.7

# === Qwen (通义千问 - 阿里云) ===
QWEN_API_KEY=sk-xxxxx
QWEN_MODEL=qwen-max

# === MiniMax ===
MINIMAX_API_KEY=xxxxx
MINIMAX_GROUP_ID=xxxxx
MINIMAX_MODEL=abab6.5-chat

# === 飞书 ===
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx
FEISHU_APP_ID=cli_xxxxx
FEISHU_APP_SECRET=xxxxx

# === 服务端口 ===
API_PORT=3001
WEB_PORT=3000
API_SECRET=your-api-secret-change-me

# === Redis (BullMQ) ===
REDIS_URL=redis://localhost:6379

# === 调度配置 ===
SPARK_CRON_1=0 8 * * *
SPARK_CRON_2=0 20 * * *
MESSAGE_CHECK_INTERVAL=300000
SESSION_HEARTBEAT_INTERVAL=1800000
