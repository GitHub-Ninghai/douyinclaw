{
  "name": "douyinclaw",
  "version": "1.0.0",
  "private": true,
  "description": "抖音社交助手 - 自动续火花 + AI智能回复",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "dev:all": "node scripts/dev.js",
    "dev:api": "node scripts/start-api.js",
