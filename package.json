    "spark:auto": "npx tsx scripts/auto-spark.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "dotenv": "^17.3.1",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "playwright": "^1.41.0"
  }
